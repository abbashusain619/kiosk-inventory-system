---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import Toast from "../../components/Toast.astro";
import ConfirmModal from "../../components/ConfirmModal.astro";
import { rawDb } from "../../db";

const { permissions } = Astro.locals;
if (!permissions?.includes("roles.manage")) {
  return Astro.redirect("/admin/dashboard");
}

const allPermissions = rawDb
  .prepare("SELECT id, name FROM permissions ORDER BY name")
  .all() as { id: number; name: string }[];

const added = Astro.url.searchParams.has("added");
const updated = Astro.url.searchParams.has("updated");
const deleted = Astro.url.searchParams.has("deleted");
const error = Astro.url.searchParams.get("error");
---

<AdminLayout>
  <div class="p-4 max-w-6xl mx-auto">
    <!-- Toasts -->
    {added && <Toast id="addToast" message="Role added successfully!" type="success" />}
    {updated && <Toast id="updateToast" message="Role updated successfully!" type="success" />}
    {deleted && <Toast id="deleteToast" message="Role deleted successfully!" type="success" />}
    {error && <Toast id="errorToast" message={error} type="error" duration={4000} />}

    <!-- Add Role Form (card) -->
    <div class="bg-white dark:bg-ash-800 rounded-xl shadow-sm p-6 mb-6">
      <h2 class="text-xl font-semibold mb-4 text-ash-800 dark:text-white">Add New Role</h2>
      <form id="addRoleForm" class="space-y-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <input
            type="text"
            id="addRoleName"
            placeholder="Role name"
            required
            class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white focus:ring-2 focus:ring-primary-500"
          />
          <input
            type="text"
            id="addRoleDesc"
            placeholder="Description (optional)"
            class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white"
          />
        </div>
        <button type="submit" class="bg-primary-500 text-white px-4 py-2 rounded-lg hover:bg-primary-600 transition">Create Role</button>
      </form>
    </div>

    <!-- Roles Table (horizontal scroll) -->
    <div class="bg-white dark:bg-ash-800 rounded-xl shadow-sm overflow-x-auto">
      <table class="w-full">
        <thead class="bg-ash-50 dark:bg-ash-700">
          <tr>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">ID</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Name</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Description</th>
            <th class="p-3 text-center text-ash-700 dark:text-ash-200">Actions</th>
          </tr>
        </thead>
        <tbody id="rolesTableBody">
          <tr><td colspan="4" class="p-3 text-center text-ash-500">Loading...</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Edit Role Modal (dark mode compatible) -->
  <div id="editRoleModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50">
    <div class="bg-white dark:bg-ash-800 rounded-xl shadow-xl max-w-2xl w-full p-6 max-h-[80vh] overflow-y-auto">
      <h3 class="text-lg font-semibold mb-4 text-ash-800 dark:text-white">Edit Role & Permissions</h3>
      <form id="editRoleForm" class="space-y-4">
        <input type="hidden" id="editRoleId" />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
          <input
            type="text"
            id="editRoleName"
            placeholder="Role name"
            required
            class="border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white"
          />
          <input
            type="text"
            id="editRoleDesc"
            placeholder="Description"
            class="border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white"
          />
        </div>
        <div>
          <label class="block font-medium text-ash-700 dark:text-ash-300 mb-2">Permissions</label>
          <div id="permissionsChecklist" class="grid grid-cols-1 sm:grid-cols-2 gap-2">
            {allPermissions.map((p) => (
              <label class="flex items-center gap-2 text-ash-700 dark:text-ash-300">
                <input type="checkbox" value={p.id} class="w-4 h-4" /> {p.name}
              </label>
            ))}
          </div>
        </div>
        <div class="flex justify-end gap-3 pt-2">
          <button type="button" id="closeEditModal" class="bg-gray-400 dark:bg-ash-700 text-white px-4 py-2 rounded-lg hover:bg-gray-500 transition">Cancel</button>
          <button type="submit" class="bg-primary-500 text-white px-4 py-2 rounded-lg hover:bg-primary-600 transition">Save Changes</button>
        </div>
      </form>
    </div>
  </div>

  <ConfirmModal />

  <script lang="js">
    document.addEventListener("DOMContentLoaded", () => {
      async function loadRoles() {
        const res = await fetch("/api/admin/roles");
        if (!res.ok) {
          const err = await res.text();
          alert(err);
          return;
        }
        const roles = await res.json();
        const tbody = document.getElementById("rolesTableBody");
        if (!tbody) return;
        tbody.innerHTML = roles.map(r => `
          <tr class="border-t border-ash-200 dark:border-ash-700">
            <td class="p-3 dark:text-ash-200">${r.id}</td>
            <td class="p-3 dark:text-ash-200">${escapeHtml(r.name)}</td>
            <td class="p-3 dark:text-ash-200">${escapeHtml(r.description || "")}</td>
            <td class="p-3 text-center">
              <button class="edit-role bg-primary-500 text-white px-2 py-1 rounded text-sm hover:bg-primary-600 transition" data-id="${r.id}" data-name="${escapeHtml(r.name)}" data-desc="${escapeHtml(r.description || "")}" data-perms='${JSON.stringify(r.permissionIds)}'>Edit</button>
              <button class="delete-role bg-red-600 text-white px-2 py-1 rounded text-sm hover:bg-red-700 transition" data-id="${r.id}" data-name="${escapeHtml(r.name)}">Del</button>
            </td>
          </tr>
        `).join('');
        attachRoleButtons();
      }

      function attachRoleButtons() {
        document.querySelectorAll(".edit-role").forEach(btn => {
          btn.addEventListener("click", () => {
            const id = btn.getAttribute("data-id");
            const name = btn.getAttribute("data-name");
            const desc = btn.getAttribute("data-desc");
            const perms = JSON.parse(btn.getAttribute("data-perms"));
            document.getElementById("editRoleId").value = id;
            document.getElementById("editRoleName").value = name;
            document.getElementById("editRoleDesc").value = desc;
            const checkboxes = document.querySelectorAll('#permissionsChecklist input[type="checkbox"]');
            checkboxes.forEach(cb => {
              const permId = parseInt(cb.value);
              cb.checked = perms.includes(permId);
            });
            const modal = document.getElementById("editRoleModal");
            if (modal) {
              modal.classList.remove("hidden");
              modal.classList.add("flex");
            }
          });
        });
        document.querySelectorAll(".delete-role").forEach(btn => {
          btn.addEventListener("click", async () => {
            const id = btn.getAttribute("data-id");
            const name = btn.getAttribute("data-name");
            const confirmed = await window.showConfirmModal({
              title: "Delete Role",
              message: `Delete role "${name}"? This action cannot be undone.`
            });
            if (confirmed) {
              const fd = new FormData();
              fd.append("id", id);
              const res = await fetch("/api/admin/delete-role", { method: "POST", body: fd });
              if (res.ok) {
                window.location.href = "/admin/roles?deleted=1";
              } else {
                const err = await res.text();
                alert(err);
              }
            }
          });
        });
      }

      function escapeHtml(str) {
        return str.replace(/[&<>]/g, m => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[m]));
      }

      const addForm = document.getElementById("addRoleForm");
      if (addForm) {
        addForm.addEventListener("submit", async (e) => {
          e.preventDefault();
          const name = document.getElementById("addRoleName").value;
          const description = document.getElementById("addRoleDesc").value;
          const fd = new FormData();
          fd.append("name", name);
          fd.append("description", description);
          const res = await fetch("/api/admin/create-role", { method: "POST", body: fd });
          if (res.ok) {
            window.location.href = "/admin/roles?added=1";
          } else {
            const err = await res.text();
            alert(err);
          }
        });
      }

      const editForm = document.getElementById("editRoleForm");
      if (editForm) {
        editForm.addEventListener("submit", async (e) => {
          e.preventDefault();
          const id = document.getElementById("editRoleId").value;
          const name = document.getElementById("editRoleName").value;
          const description = document.getElementById("editRoleDesc").value;
          const checkedPerms = [];
          document.querySelectorAll('#permissionsChecklist input[type="checkbox"]:checked').forEach(cb => {
            checkedPerms.push(parseInt(cb.value));
          });
          let fd = new FormData();
          fd.append("id", id);
          fd.append("name", name);
          fd.append("description", description);
          let res = await fetch("/api/admin/update-role", { method: "POST", body: fd });
          if (!res.ok) {
            const err = await res.text();
            alert(err);
            return;
          }
          fd = new FormData();
          fd.append("roleId", id);
          fd.append("permissionIds", checkedPerms.join(","));
          res = await fetch("/api/admin/assign-role-permissions", { method: "POST", body: fd });
          if (res.ok) {
            window.location.href = "/admin/roles?updated=1";
          } else {
            const err = await res.text();
            alert(err);
          }
        });
      }

      const closeModalBtn = document.getElementById("closeEditModal");
      if (closeModalBtn) {
        closeModalBtn.addEventListener("click", () => {
          const modal = document.getElementById("editRoleModal");
          if (modal) {
            modal.classList.remove("flex");
            modal.classList.add("hidden");
          }
        });
      }
      window.addEventListener("click", (e) => {
        const modal = document.getElementById("editRoleModal");
        if (e.target === modal && modal) {
          modal.classList.remove("flex");
          modal.classList.add("hidden");
        }
      });

      loadRoles();
    });
  </script>
</AdminLayout>