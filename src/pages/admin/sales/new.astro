---
const success = Astro.url.searchParams.has("success");
export const prerender = false;
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { rawDb } from "../../../db";
import BarcodeScanner from "../../../components/BarcodeScanner.astro";

const { permissions } = Astro.locals;
if (!permissions?.includes("sales.create")) {
  return Astro.redirect("/admin/dashboard");
}

// Fetch all active products (only needed fields)
const products = rawDb
  .prepare(
    "SELECT id, name, price, stock, unit FROM products WHERE active = 1 ORDER BY name"
  )
  .all() as {
  id: number;
  name: string;
  price: number;
  stock: number;
  unit: string;
}[];
---

<AdminLayout>
  <div class="p-4 max-w-4xl mx-auto">
    <!-- Success toast -->
    {success && (
      <div
        id="toast"
        class="fixed top-4 right-4 bg-green-600 text-white px-4 py-2 rounded shadow z-50"
      >
        Sale completed successfully!
      </div>
    )}

    <!-- Product selector card -->
    <div class="bg-white dark:bg-ash-800 rounded-xl shadow-sm p-4 mb-6">
      <div class="grid grid-cols-1 md:grid-cols-5 gap-3 items-end">
        <div class="md:col-span-2">
          <label class="block font-medium text-ash-700 dark:text-ash-300 mb-1">Product</label>
          <select id="productSelect" class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white">
            <option value="">Select product</option>
            {products.map((p) => (
              <option value={p.id} data-price={p.price} data-stock={p.stock}>
                {p.name} - Tsh {p.price} (stock: {p.stock} {p.unit || "piece"})
              </option>
            ))}
          </select>
        </div>
        <div>
          <label class="block font-medium text-ash-700 dark:text-ash-300 mb-1">Qty</label>
          <input
            type="number"
            id="quantity"
            value="1"
            min="1"
            class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white"
          />
        </div>
        <div>
          <label class="block font-medium text-ash-700 dark:text-ash-300 mb-1">Unit</label>
          <select id="unitSelect" class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white">
            <option value="base">piece</option>
          </select>
        </div>
        <button id="addBtn" class="bg-primary-500 text-white px-4 py-2 rounded-lg hover:bg-primary-600 transition">Add</button>
      </div>
    </div>

    <!-- Barcode / SKU manual entry + scanner -->
    <div class="bg-white dark:bg-ash-800 rounded-xl shadow-sm p-4 mb-6">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-3 items-end">
        <div class="md:col-span-1">
          <label class="block font-medium text-ash-700 dark:text-ash-300 mb-1">SKU / Barcode</label>
          <input
            type="text"
            id="barcodeInput"
            placeholder="Type or scan"
            class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white"
          />
        </div>
        <button id="addByCodeBtn" class="bg-primary-500 text-white px-4 py-2 rounded-lg hover:bg-primary-600 transition">Add by Code</button>
        <button id="scanBarcodeBtn" class="bg-secondary-500 text-white px-4 py-2 rounded-lg hover:bg-secondary-600 transition">Scan Barcode</button>
      </div>
    </div>

    <!-- Basket table (horizontal scroll) -->
    <div class="bg-white dark:bg-ash-800 rounded-xl shadow-sm overflow-x-auto mb-6">
      <table class="w-full">
        <thead class="bg-ash-50 dark:bg-ash-700">
          <tr>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Product</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Qty</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Unit Price</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Total</th>
            <th class="p-3 text-center text-ash-700 dark:text-ash-200"></th>
          </tr>
        </thead>
        <tbody id="basketBody"></tbody>
        <tfoot class="border-t border-ash-200 dark:border-ash-700">
          <tr class="font-bold">
            <td colspan="3" class="p-3 text-right text-ash-700 dark:text-ash-200">Subtotal:</td>
            <td class="p-3 text-ash-800 dark:text-white" id="subtotal">0</td>
            <td></td>
          </tr>
          <tr>
            <td colspan="3" class="p-3 text-right text-ash-700 dark:text-ash-200">Discount:</td>
            <td class="p-3">
              <div class="flex gap-2">
                <select id="discountType" class="border border-ash-300 dark:border-ash-600 rounded px-2 py-1 text-sm dark:bg-ash-800 dark:text-white">
                  <option value="percentage">%</option>
                  <option value="fixed">Tsh</option>
                </select>
                <input
                  type="number"
                  id="discountValue"
                  value="0"
                  min="0"
                  class="w-24 border border-ash-300 dark:border-ash-600 rounded px-2 py-1 text-sm dark:bg-ash-800 dark:text-white"
                />
              </div>
            </td>
            <td></td>
          </tr>
          <tr class="font-bold text-lg">
            <td colspan="3" class="p-3 text-right text-ash-700 dark:text-ash-200">Final Total:</td>
            <td class="p-3 text-primary-600 dark:text-primary-400" id="finalTotal">0</td>
            <td></td>
          </tr>
        </tfoot>
      </table>
    </div>

    <div class="flex gap-3">
      <button id="completeSaleBtn" class="bg-green-600 text-white px-6 py-2 rounded-lg hover:bg-green-700 transition">Complete Sale</button>
      <a href="/admin/products" class="bg-gray-500 text-white px-4 py-2 rounded-lg hover:bg-gray-600 transition">Cancel</a>
    </div>
  </div>

  <script define:vars={{ products }}>
    let basket = [];
    const productsData = products;

    const productSelect = document.getElementById("productSelect");
    const quantityInput = document.getElementById("quantity");
    const unitSelect = document.getElementById("unitSelect");
    const addBtn = document.getElementById("addBtn");
    const basketBody = document.getElementById("basketBody");
    const subtotalSpan = document.getElementById("subtotal");
    const discountType = document.getElementById("discountType");
    const discountValue = document.getElementById("discountValue");
    const finalTotalSpan = document.getElementById("finalTotal");
    const completeBtn = document.getElementById("completeSaleBtn");
    const barcodeInput = document.getElementById("barcodeInput");
    const addByCodeBtn = document.getElementById("addByCodeBtn");
    const scanBarcodeBtn = document.getElementById("scanBarcodeBtn");

    let currentUnit = "piece";
    let currentBulkUnit = null;
    let currentBulkFactor = 1;

    const toast = document.getElementById("toast");
    if (toast) {
      setTimeout(() => {
        toast.style.opacity = "0";
        setTimeout(() => toast.remove(), 500);
      }, 3000);
    }

    async function loadProductUnits(productId) {
      if (!productId) return;
      const res = await fetch(`/api/product-unit?id=${productId}`);
      if (res.ok) {
        const data = await res.json();
        currentUnit = data.unit || "piece";
        currentBulkUnit = data.bulkUnit;
        currentBulkFactor = data.bulkFactor || 1;
        unitSelect.innerHTML = `<option value="base">${currentUnit}</option>`;
        if (currentBulkUnit) unitSelect.innerHTML += `<option value="bulk">${currentBulkUnit}</option>`;
      } else {
        unitSelect.innerHTML = `<option value="base">piece</option>`;
      }
    }

    function addProductToBasket(productId, name, unitPrice, qty) {
      const product = productsData.find(p => p.id === productId);
      if (!product) return false;
      if (qty > product.stock) {
        window.showToast(`Only ${product.stock} in stock`, "error");
        return false;
      }
      const existing = basket.find(item => item.productId === productId);
      if (existing) {
        const newQty = existing.qty + qty;
        if (newQty > product.stock) {
          window.showToast(`Cannot add. Stock would exceed ${product.stock}`, "error");
          return false;
        }
        existing.qty = newQty;
        existing.total = newQty * existing.unitPrice;
      } else {
        basket.push({
          productId: product.id,
          name: product.name,
          qty: qty,
          unitPrice: product.price,
          total: qty * product.price,
        });
      }
      renderBasket();
      return true;
    }

    function updateTotals() {
      const subtotal = basket.reduce((sum, item) => sum + item.total, 0);
      if (subtotalSpan) subtotalSpan.innerText = subtotal.toFixed(0);
      let discount = 0;
      const discVal = discountValue ? parseFloat(discountValue.value) || 0 : 0;
      if (discountType && discountType.value === "percentage") {
        discount = subtotal * (discVal / 100);
      } else {
        discount = discVal;
      }
      const final = Math.max(0, subtotal - discount);
      if (finalTotalSpan) finalTotalSpan.innerText = final.toFixed(0);
    }

    function renderBasket() {
      if (!basketBody) return;
      basketBody.innerHTML = "";
      basket.forEach((item, idx) => {
        const row = document.createElement("tr");
        row.className = "border-t border-ash-200 dark:border-ash-700";
        row.innerHTML = `
          <td class="p-3 dark:text-ash-200">${escapeHtml(item.name)}</td>
          <td class="p-3"><input type="number" class="qty-change w-20 border border-ash-300 dark:border-ash-600 rounded px-2 py-1 text-sm dark:bg-ash-800 dark:text-white" data-idx="${idx}" value="${item.qty}" min="1" step="1" /></td>
          <td class="p-3 dark:text-ash-200">${item.unitPrice}</td>
          <td class="p-3 dark:text-ash-200">${(item.qty * item.unitPrice).toFixed(0)}</td>
          <td class="p-3 text-center"><button class="remove-item text-red-600 hover:text-red-800 transition" data-idx="${idx}">✕</button></td>
        `;
        basketBody.appendChild(row);
      });
      attachBasketEvents();
      updateTotals();
    }

    function attachBasketEvents() {
      document.querySelectorAll(".qty-change").forEach(input => {
        input.removeEventListener("change", handleQtyChange);
        input.addEventListener("change", handleQtyChange);
      });
      document.querySelectorAll(".remove-item").forEach(btn => {
        btn.removeEventListener("click", handleRemove);
        btn.addEventListener("click", handleRemove);
      });
    }

    function handleQtyChange(e) {
      const target = e.target;
      const idx = parseInt(target.dataset.idx);
      const newQty = parseInt(target.value);
      if (!isNaN(newQty) && newQty > 0 && basket[idx]) {
        const product = productsData.find(p => p.id === basket[idx].productId);
        if (product && newQty > product.stock) {
          window.showToast(`Only ${product.stock} in stock`, "error");
          target.value = basket[idx].qty;
          return;
        }
        basket[idx].qty = newQty;
        basket[idx].total = newQty * basket[idx].unitPrice;
        renderBasket();
      }
    }

    function handleRemove(e) {
      const idx = parseInt(e.target.dataset.idx);
      basket.splice(idx, 1);
      renderBasket();
    }

    function escapeHtml(str) {
      return str.replace(/[&<>]/g, m => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[m]));
    }

    productSelect.addEventListener("change", () => {
      const productId = productSelect.value;
      if (productId) loadProductUnits(productId);
      else unitSelect.innerHTML = `<option value="base">piece</option>`;
    });

    if (addBtn && productSelect && quantityInput) {
      addBtn.addEventListener("click", () => {
        const productId = parseInt(productSelect.value);
        if (!productId) return;
        const product = productsData.find(p => p.id === productId);
        if (!product) return;
        let rawQty = quantityInput ? parseFloat(quantityInput.value) : 1;
        if (isNaN(rawQty) || rawQty < 1) rawQty = 1;
        const selectedUnit = unitSelect.value;
        let baseQty = rawQty;
        if (selectedUnit === "bulk" && currentBulkUnit && currentBulkFactor > 0) {
          baseQty = rawQty * currentBulkFactor;
        }
        addProductToBasket(productId, product.name, product.price, baseQty);
        productSelect.value = "";
        if (quantityInput) quantityInput.value = "1";
        unitSelect.innerHTML = `<option value="base">piece</option>`;
      });
    }

    if (addByCodeBtn && barcodeInput) {
      addByCodeBtn.addEventListener("click", async () => {
        const code = barcodeInput.value.trim();
        if (!code) return;
        const res = await fetch(`/api/product-by-barcode?code=${encodeURIComponent(code)}`);
        if (res.ok) {
          const product = await res.json();
          await loadProductUnits(product.id);
          let rawQty = 1;
          const selectedUnit = unitSelect.value;
          let baseQty = rawQty;
          if (selectedUnit === "bulk" && currentBulkUnit && currentBulkFactor > 0) {
            baseQty = rawQty * currentBulkFactor;
          }
          addProductToBasket(product.id, product.name, product.price, baseQty);
          barcodeInput.value = "";
        } else {
          window.showToast("Product not found", "error");
        }
      });
    }

    if (scanBarcodeBtn) {
      scanBarcodeBtn.addEventListener("click", () => {
        window.showBarcodeScanner(async (barcode) => {
          const res = await fetch(`/api/product-by-barcode?code=${encodeURIComponent(barcode)}`);
          if (res.ok) {
            const product = await res.json();
            await loadProductUnits(product.id);
            let rawQty = 1;
            const selectedUnit = unitSelect.value;
            let baseQty = rawQty;
            if (selectedUnit === "bulk" && currentBulkUnit && currentBulkFactor > 0) {
              baseQty = rawQty * currentBulkFactor;
            }
            addProductToBasket(product.id, product.name, product.price, baseQty);
          } else {
            window.showToast("Product not found", "error");
          }
        });
      });
    }

    if (discountType && discountValue) {
      discountType.addEventListener("change", updateTotals);
      discountValue.addEventListener("input", updateTotals);
    }

    if (completeBtn) {
      completeBtn.addEventListener("click", async () => {
        if (basket.length === 0) {
          window.showToast("Add at least one product", "error");
          return;
        }
        const subtotal = basket.reduce((sum, item) => sum + item.total, 0);
        let discount = 0;
        const discVal = discountValue ? parseFloat(discountValue.value) || 0 : 0;
        if (discountType && discountType.value === "percentage") {
          discount = subtotal * (discVal / 100);
        } else {
          discount = discVal;
        }
        const finalTotal = subtotal - discount;
        const payload = {
          items: basket.map(item => ({ productId: item.productId, quantity: item.qty, unitPrice: item.unitPrice })),
          discountType: discountType?.value || "fixed",
          discountValue: discVal,
          finalAmount: finalTotal,
        };
        const response = await fetch("/api/complete-sale", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
        if (response.ok) {
          window.location.href = "/admin/sales/new?success=1";
        } else {
          const err = await response.text();
          window.showToast(err, "error");
        }
      });
    }
  </script>
  <BarcodeScanner />
</AdminLayout>