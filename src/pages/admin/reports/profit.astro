---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';

const { permissions } = Astro.locals;
if (!permissions?.includes('reports.profit')) {
  return Astro.redirect('/admin/dashboard');
}
---

<AdminLayout>
  <div class="p-4">
    <!-- Filter controls -->
    <div class="bg-white dark:bg-ash-800 rounded-xl shadow-sm p-4 mb-6">
      <div class="flex flex-wrap gap-2 items-end">
        <div>
          <label class="block text-sm font-medium text-ash-700 dark:text-ash-300 mb-1">From Date</label>
          <input type="date" id="fromDate" class="border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white" />
        </div>
        <div>
          <label class="block text-sm font-medium text-ash-700 dark:text-ash-300 mb-1">To Date</label>
          <input type="date" id="toDate" class="border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white" />
        </div>
        <button id="filterBtn" class="bg-primary-500 text-white px-4 py-2 rounded-lg hover:bg-primary-600 transition">Filter</button>
        <button id="exportBtn" class="bg-secondary-500 text-white px-4 py-2 rounded-lg hover:bg-secondary-600 transition">Export CSV</button>
      </div>
    </div>

    <!-- Summary cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
      <div class="bg-white dark:bg-ash-800 rounded-xl shadow-sm p-4 border border-ash-200 dark:border-ash-700">
        <div class="text-ash-500 dark:text-ash-400 text-sm font-medium">Total Revenue</div>
        <div class="text-2xl font-bold text-ash-800 dark:text-white mt-1" id="totalRevenue">0</div>
        <div class="text-xs text-ash-400 mt-1">Tsh</div>
      </div>
      <div class="bg-white dark:bg-ash-800 rounded-xl shadow-sm p-4 border border-ash-200 dark:border-ash-700">
        <div class="text-ash-500 dark:text-ash-400 text-sm font-medium">Total Cost</div>
        <div class="text-2xl font-bold text-ash-800 dark:text-white mt-1" id="totalCost">0</div>
        <div class="text-xs text-ash-400 mt-1">Tsh</div>
      </div>
      <div class="bg-white dark:bg-ash-800 rounded-xl shadow-sm p-4 border border-ash-200 dark:border-ash-700">
        <div class="text-ash-500 dark:text-ash-400 text-sm font-medium">Total Profit</div>
        <div class="text-2xl font-bold text-green-600 dark:text-green-400 mt-1" id="totalProfit">0</div>
        <div class="text-xs text-ash-400 mt-1">Tsh</div>
      </div>
    </div>

    <!-- Profit table (horizontal scroll) -->
    <div class="bg-white dark:bg-ash-800 rounded-xl shadow-sm overflow-x-auto">
      <table class="w-full">
        <thead class="bg-ash-50 dark:bg-ash-700">
          <tr>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Product</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Qty Sold</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Revenue (Tsh)</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Cost (Tsh)</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Profit (Tsh)</th>
          </tr>
        </thead>
        <tbody id="profitTableBody"></tbody>
      </table>
    </div>
  </div>

  <script lang="js">
    let currentData = null;

    async function fetchProfit(from, to) {
      try {
        const params = new URLSearchParams();
        if (from) params.append('from', from);
        if (to) params.append('to', to);
        const res = await fetch(`/api/profit-report?${params.toString()}`);
        const data = await res.json();
        currentData = data;
        document.getElementById('totalRevenue').innerText = data.summary.totalRevenue.toFixed(0);
        document.getElementById('totalCost').innerText = data.summary.totalCost.toFixed(0);
        document.getElementById('totalProfit').innerText = data.summary.totalProfit.toFixed(0);
        const tbody = document.getElementById('profitTableBody');
        if (tbody) {
          tbody.innerHTML = data.rows.map(r => `
            <tr class="border-t border-ash-200 dark:border-ash-700">
              <td class="p-3 dark:text-ash-200">${escapeHtml(r.name)}</td>
              <td class="p-3 dark:text-ash-200">${r.quantity_sold}</td>
              <td class="p-3 dark:text-ash-200">${r.total_revenue.toFixed(0)}</td>
              <td class="p-3 dark:text-ash-200">${(r.total_cost || 0).toFixed(0)}</td>
              <td class="p-3 dark:text-ash-200">${(r.profit || 0).toFixed(0)}</td>
            </tr>
          `).join('');
        }
      } catch(e) { console.error(e); }
    }

    function escapeHtml(str) {
      return str.replace(/[&<>]/g, m => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[m]));
    }

    const fromInput = document.getElementById('fromDate');
    const toInput = document.getElementById('toDate');
    const filterBtn = document.getElementById('filterBtn');
    const exportBtn = document.getElementById('exportBtn');

    // Default last 30 days
    const today = new Date();
    const monthAgo = new Date(); monthAgo.setDate(today.getDate() - 30);
    if (fromInput && toInput) {
      fromInput.value = monthAgo.toISOString().slice(0,10);
      toInput.value = today.toISOString().slice(0,10);
      fetchProfit(fromInput.value, toInput.value);
    }

    if (filterBtn) {
      filterBtn.addEventListener('click', () => {
        if (fromInput && toInput) fetchProfit(fromInput.value, toInput.value);
      });
    }

    if (exportBtn) {
      exportBtn.addEventListener('click', () => {
        if (!currentData) return;
        const rows = currentData.rows;
        const csv = [
          ['Product', 'Qty Sold', 'Revenue (Tsh)', 'Cost (Tsh)', 'Profit (Tsh)'],
          ...rows.map(r => [r.name, r.quantity_sold, r.total_revenue, r.total_cost || 0, r.profit || 0]),
          [],
          ['Summary', '', `Total Revenue: ${currentData.summary.totalRevenue}`, `Total Cost: ${currentData.summary.totalCost}`, `Total Profit: ${currentData.summary.totalProfit}`]
        ].map(row => row.join(',')).join('\n');
        const blob = new Blob([csv], { type: 'text/csv' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `profit-${new Date().toISOString().slice(0,10)}.csv`;
        a.click();
        URL.revokeObjectURL(url);
      });
    }
  </script>
</AdminLayout>