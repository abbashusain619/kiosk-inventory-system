---
import Layout from '../../layouts/Layout.astro';
const { userId } = Astro.locals;
if (userId) return Astro.redirect('/admin/dashboard');
---

<Layout>
  <div class="max-w-sm mx-auto mt-20 p-6 bg-white rounded shadow">
    <h1 class="text-2xl font-bold mb-4">Admin Login</h1>
    <form method="post" action="/api/login" enctype="application/x-www-form-urlencoded">
      <input type="email" name="email" placeholder="Email" class="w-full p-2 border rounded mb-2" required />
      <input type="password" name="password" placeholder="Password" class="w-full p-2 border rounded mb-2" required />
      <button type="submit" class="bg-blue-600 text-white p-2 w-full rounded">Login</button>
    </form>
  </div>
</Layout>