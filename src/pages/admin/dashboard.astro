---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { rawDb } from '../../db';

const settingsRows = rawDb.prepare('SELECT key, value FROM site_settings').all() as { key: string; value: string }[];
const settings = Object.fromEntries(settingsRows.map(s => [s.key, s.value]));
---

<AdminLayout>
  <div class="space-y-6">
    <h1 class="text-2xl font-bold">Dashboard</h1>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
      <div class="bg-white p-4 rounded shadow">
        <div class="text-gray-500 text-sm">Total Products</div>
        <div class="text-2xl font-bold" id="stat-total">0</div>
      </div>
      <div class="bg-white p-4 rounded shadow">
        <div class="text-gray-500 text-sm">Low Stock ({'<5'})</div>
        <div class="text-2xl font-bold text-orange-600" id="stat-low">0</div>
      </div>
      <div class="bg-white p-4 rounded shadow">
        <div class="text-gray-500 text-sm">Today's Sales</div>
        <div class="text-2xl font-bold text-green-600" id="stat-sales">Tsh 0</div>
      </div>
      <div class="bg-white p-4 rounded shadow">
        <div class="text-gray-500 text-sm">Inventory Value</div>
        <div class="text-2xl font-bold" id="stat-value">Tsh 0</div>
      </div>
    </div>

    <!-- Contact Info Preview -->
    <div class="bg-white p-4 rounded shadow">
      <div class="flex justify-between items-center mb-2">
        <h2 class="text-xl font-semibold">Contact Information</h2>
        <a href="/admin/settings" class="text-blue-600 text-sm">Edit</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-2 text-sm">
        <div><span class="font-semibold">Business Name:</span> {settings.businessName || 'Not set'}</div>
        <div><span class="font-semibold">WhatsApp:</span> {settings.whatsappNumber || 'Not set'}</div>
        <div><span class="font-semibold">Phone:</span> {settings.phoneNumber || 'Not set'}</div>
        <div><span class="font-semibold">Location:</span> {settings.locationText || 'Not set'}</div>
        <div><span class="font-semibold">Hours:</span> {settings.openingHours || 'Not set'}</div>
      </div>
    </div>

    <!-- Recent Stock Movements & Recent Sales -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="bg-white p-4 rounded shadow">
        <h2 class="text-xl font-semibold mb-2">Recent Stock Movements</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-gray-100">
              <tr><th class="p-2">Product</th><th class="p-2">Type</th><th class="p-2">Qty</th><th class="p-2">Date</th></tr>
            </thead>
            <tbody id="recent-movements-tbody">
              <tr><td colspan="4" class="p-2 text-center">Loading...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
      <div class="bg-white p-4 rounded shadow">
        <h2 class="text-xl font-semibold mb-2">Recent Sales</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead class="bg-gray-100">
              <tr><th class="p-2">Sale ID</th><th class="p-2">Items</th><th class="p-2">Total</th><th class="p-2">Date</th></tr>
            </thead>
            <tbody id="recent-sales-tbody">
              <tr><td colspan="4" class="p-2 text-center">Loading...</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <script lang="js">
    async function updateDashboardStats() {
      try {
        const res = await fetch('/api/dashboard-stats');
        const stats = await res.json();
        document.getElementById('stat-total').innerText = stats.totalProducts;
        document.getElementById('stat-low').innerText = stats.lowStockCount;
        document.getElementById('stat-sales').innerText = 'Tsh ' + stats.todaySales.toFixed(0);
        document.getElementById('stat-value').innerText = 'Tsh ' + stats.inventoryValue.toFixed(0);
      } catch(e) { console.error(e); }
    }

    async function loadRecentData() {
      try {
        const movementsRes = await fetch('/api/recent-movements');
        const movements = await movementsRes.json();
        const movementsTbody = document.getElementById('recent-movements-tbody');
        if (movementsTbody) {
          if (movements.length === 0) {
            movementsTbody.innerHTML = '<tr><td colspan="4" class="p-2 text-center">No movements yet</td></tr>';
          } else {
            movementsTbody.innerHTML = movements.map(m => `
              <tr class="border-t">
                <td class="p-2">${escapeHtml(m.product_name)}</td>
                <td class="p-2">${m.type}</td>
                <td class="p-2">${m.quantity}</td>
                <td class="p-2">${new Date(m.created_at).toLocaleDateString()}</td>
              </tr>
            `).join('');
          }
        }

        const salesRes = await fetch('/api/recent-sales');
        const sales = await salesRes.json();
        const salesTbody = document.getElementById('recent-sales-tbody');
        if (salesTbody) {
          if (sales.length === 0) {
            salesTbody.innerHTML = '<tr><td colspan="4" class="p-2 text-center">No sales yet</td></tr>';
          } else {
            salesTbody.innerHTML = sales.map(s => `
              <tr class="border-t">
                <td class="p-2">${s.id}</td>
                <td class="p-2">${s.item_count}</td>
                <td class="p-2">Tsh ${s.final_amount}</td>
                <td class="p-2">${new Date(s.completed_at).toLocaleDateString()}</td>
              </tr>
            `).join('');
          }
        }
      } catch(e) { console.error(e); }
    }

    function escapeHtml(str) {
      return str.replace(/[&<>]/g, function(m) {
        if (m === '&') return '&amp;';
        if (m === '<') return '&lt;';
        if (m === '>') return '&gt;';
        return m;
      });
    }

    updateDashboardStats();
    loadRecentData();

    // Listen to global SSE events (dispatched from Layout.astro)
    window.addEventListener('sse:stock-update', () => {
      updateDashboardStats();
      loadRecentData();
    });
    window.addEventListener('sse:product-created', () => {
      updateDashboardStats();
      loadRecentData();
    });
    window.addEventListener('sse:product-deleted', () => {
      updateDashboardStats();
      loadRecentData();
    });
    window.addEventListener('sse:product-updated', () => {
      updateDashboardStats();
      loadRecentData();
    });
    window.addEventListener('sse:sale-completed', () => {
      updateDashboardStats();
      loadRecentData();
    });
  </script>
</AdminLayout>