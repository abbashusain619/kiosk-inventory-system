---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { rawDb } from '../../db';

const settingsRows = rawDb.prepare('SELECT key, value FROM site_settings').all() as { key: string; value: string }[];
const settings = Object.fromEntries(settingsRows.map(s => [s.key, s.value]));

const defaults = {
  businessName: settings.businessName || '',
  whatsappNumber: settings.whatsappNumber || '',
  phoneNumber: settings.phoneNumber || '',
  locationText: settings.locationText || '',
  mapLink: settings.mapLink || '',
  openingHours: settings.openingHours || '',
  promoText: settings.promoText || '',
};
---

<AdminLayout>
  <div class="max-w-2xl mx-auto">
    <h1 class="text-2xl font-bold mb-6">Business Settings</h1>
    <form method="post" action="/api/update-settings" class="bg-white p-6 rounded shadow space-y-4">
      <div>
        <label class="block font-semibold">Business Name</label>
        <input type="text" name="businessName" value={defaults.businessName} class="w-full border p-2 rounded" />
      </div>
      <div>
        <label class="block font-semibold">WhatsApp Number (e.g., 255700000000)</label>
        <input type="text" name="whatsappNumber" value={defaults.whatsappNumber} class="w-full border p-2 rounded" />
      </div>
      <div>
        <label class="block font-semibold">Phone Number</label>
        <input type="text" name="phoneNumber" value={defaults.phoneNumber} class="w-full border p-2 rounded" />
      </div>
      <div>
        <label class="block font-semibold">Location Text</label>
        <input type="text" name="locationText" value={defaults.locationText} class="w-full border p-2 rounded" />
      </div>
      <div>
        <label class="block font-semibold">Map Link</label>
        <input type="text" name="mapLink" value={defaults.mapLink} class="w-full border p-2 rounded" />
      </div>
      <div>
        <label class="block font-semibold">Opening Hours</label>
        <input type="text" name="openingHours" value={defaults.openingHours} class="w-full border p-2 rounded" />
      </div>
      <div>
        <label class="block font-semibold">Promo Text</label>
        <textarea name="promoText" class="w-full border p-2 rounded" rows="2">{defaults.promoText}</textarea>
      </div>
      <button type="submit" class="bg-blue-600 text-white px-4 py-2 rounded">Save Settings</button>
    </form>
  </div>
</AdminLayout>