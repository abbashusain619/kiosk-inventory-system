---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { rawDb } from '../../db';

const settingsRows = rawDb.prepare('SELECT key, value FROM site_settings').all() as { key: string; value: string }[];
const settings = Object.fromEntries(settingsRows.map(s => [s.key, s.value]));

const defaults = {
  businessName: settings.businessName || '',
  whatsappNumber: settings.whatsappNumber || '',
  phoneNumber: settings.phoneNumber || '',
  locationText: settings.locationText || '',
  mapLink: settings.mapLink || '',
  openingHours: settings.openingHours || '',
  promoText: settings.promoText || '',
};
---

<AdminLayout>
  <div class="p-4 max-w-2xl mx-auto">
    <!-- Settings form card -->
    <div class="bg-white dark:bg-ash-800 rounded-xl shadow-sm p-6">
      <form method="post" action="/api/update-settings" class="space-y-5">
        <!-- Business Name -->
        <div>
          <label class="block font-medium text-ash-700 dark:text-ash-300 mb-1">Business Name</label>
          <input
            type="text"
            name="businessName"
            value={defaults.businessName}
            class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white focus:ring-2 focus:ring-primary-500"
          />
        </div>

        <!-- WhatsApp Number -->
        <div>
          <label class="block font-medium text-ash-700 dark:text-ash-300 mb-1">WhatsApp Number (e.g., 255700000000)</label>
          <input
            type="text"
            name="whatsappNumber"
            value={defaults.whatsappNumber}
            class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white"
          />
        </div>

        <!-- Phone Number -->
        <div>
          <label class="block font-medium text-ash-700 dark:text-ash-300 mb-1">Phone Number</label>
          <input
            type="text"
            name="phoneNumber"
            value={defaults.phoneNumber}
            class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white"
          />
        </div>

        <!-- Location Text -->
        <div>
          <label class="block font-medium text-ash-700 dark:text-ash-300 mb-1">Location Text</label>
          <input
            type="text"
            name="locationText"
            value={defaults.locationText}
            class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white"
          />
        </div>

        <!-- Map Link -->
        <div>
          <label class="block font-medium text-ash-700 dark:text-ash-300 mb-1">Map Link</label>
          <input
            type="text"
            name="mapLink"
            value={defaults.mapLink}
            class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white"
          />
        </div>

        <!-- Opening Hours -->
        <div>
          <label class="block font-medium text-ash-700 dark:text-ash-300 mb-1">Opening Hours</label>
          <input
            type="text"
            name="openingHours"
            value={defaults.openingHours}
            class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white"
          />
        </div>

        <!-- Promo Text -->
        <div>
          <label class="block font-medium text-ash-700 dark:text-ash-300 mb-1">Promo Text</label>
          <textarea
            name="promoText"
            rows="2"
            class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white"
          >{defaults.promoText}</textarea>
        </div>

        <!-- Submit Button -->
        <div class="pt-2">
          <button
            type="submit"
            class="bg-primary-500 text-white px-5 py-2 rounded-lg hover:bg-primary-600 transition shadow-sm"
          >
            Save Settings
          </button>
        </div>
      </form>
    </div>
  </div>
</AdminLayout>