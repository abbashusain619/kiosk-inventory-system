---
const added = Astro.url.searchParams.has('added');
const updated = Astro.url.searchParams.has('updated');
const deleted = Astro.url.searchParams.has('deleted');
const error = Astro.url.searchParams.get('error');
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import ConfirmModal from '../../components/ConfirmModal.astro';
import Toast from '../../components/Toast.astro';
import { rawDb } from '../../db';

const { permissions } = Astro.locals;
const canEdit = permissions?.includes('suppliers.edit') ?? false;

const suppliers = rawDb.prepare('SELECT id, name, phone, email, address, created_at FROM suppliers ORDER BY name').all() as any[];
---

<AdminLayout>
  <div class="max-w-5xl mx-auto">
    <h1 class="text-2xl font-bold mb-4">Manage Suppliers</h1>

    <!-- Toasts -->
    {added && <Toast id="addToast" message="Supplier added successfully!" type="success" />}
    {updated && <Toast id="updateToast" message="Supplier updated successfully!" type="success" />}
    {deleted && <Toast id="deleteToast" message="Supplier deleted successfully!" type="success" />}
    {error === 'used' && <Toast id="errorToast" message="Cannot delete: supplier has linked stock movements" type="error" duration={4000} />}

    <!-- Add Supplier Form (only if can edit) -->
    {canEdit && (
      <div class="bg-white p-4 rounded shadow mb-6">
        <h2 class="text-xl font-semibold mb-3">Add New Supplier</h2>
        <form method="post" action="/api/add-supplier">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
            <input type="text" name="name" placeholder="Supplier name" required class="border p-2 rounded" />
            <input type="text" name="phone" placeholder="Phone" class="border p-2 rounded" />
            <input type="email" name="email" placeholder="Email" class="border p-2 rounded" />
          </div>
          <div class="mt-3">
            <input type="text" name="address" placeholder="Address" class="border p-2 rounded w-full" />
          </div>
          <button type="submit" class="mt-3 bg-green-600 text-white px-4 py-2 rounded">Add Supplier</button>
        </form>
      </div>
    )}

    <!-- Suppliers Table -->
    <div class="bg-white rounded shadow overflow-x-auto">
      <table class="w-full min-w-[800px]">
        <thead class="bg-gray-100">
          <tr>
            <th class="p-2">Name</th>
            <th class="p-2">Phone</th>
            <th class="p-2">Email</th>
            <th class="p-2">Address</th>
            <th class="p-2">Actions</th>
          </tr>
        </thead>
        <tbody>
          {suppliers.map(s => (
            <tr class="border-t" data-supplier-name={s.name}>
              <form method="post" action="/api/update-supplier" class="inline-flex gap-1 items-center">
                <input type="hidden" name="id" value={s.id} />
                <td class="p-2"><input type="text" name="name" value={s.name} class="border p-1 w-32" required disabled={!canEdit} /></td>
                <td class="p-2"><input type="text" name="phone" value={s.phone || ''} class="border p-1 w-32" disabled={!canEdit} /></td>
                <td class="p-2"><input type="email" name="email" value={s.email || ''} class="border p-1 w-32" disabled={!canEdit} /></td>
                <td class="p-2"><input type="text" name="address" value={s.address || ''} class="border p-1 w-48" disabled={!canEdit} /></td>
                <td class="p-2">
                  {canEdit && <button type="submit" class="bg-blue-600 text-white px-2 py-1 rounded text-sm">Save</button>}
                  {canEdit && <button type="button" class="del-btn bg-red-600 text-white px-2 py-1 rounded text-sm" data-id={s.id} data-name={s.name}>Del</button>}
                </td>
              </form>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <ConfirmModal />

  <script lang="js">
    // Delete confirmation using modal (only if buttons exist)
    document.querySelectorAll('.del-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const id = btn.getAttribute('data-id');
        const name = btn.getAttribute('data-name');
        const confirmed = await window.showConfirmModal({
          title: 'Delete Supplier',
          message: `Delete supplier "${name}"? This action cannot be undone.`
        });
        if (confirmed) {
          const form = document.createElement('form');
          form.method = 'POST';
          form.action = '/api/delete-supplier';
          const input = document.createElement('input');
          input.type = 'hidden';
          input.name = 'id';
          input.value = id;
          form.appendChild(input);
          document.body.appendChild(form);
          form.submit();
        }
      });
    });
  </script>
</AdminLayout>