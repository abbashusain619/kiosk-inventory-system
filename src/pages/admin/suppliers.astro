---
const added = Astro.url.searchParams.has('added');
const updated = Astro.url.searchParams.has('updated');
const deleted = Astro.url.searchParams.has('deleted');
const error = Astro.url.searchParams.get('error');
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import ConfirmModal from '../../components/ConfirmModal.astro';
import Toast from '../../components/Toast.astro';
import { rawDb } from '../../db';

const { permissions } = Astro.locals;
const canEdit = permissions?.includes('suppliers.edit') ?? false;

const suppliers = rawDb.prepare('SELECT id, name, phone, email, address, created_at FROM suppliers ORDER BY name').all() as any[];
---

<AdminLayout>
  <div class="p-4 max-w-5xl mx-auto">
    <!-- Toasts -->
    {added && <Toast id="addToast" message="Supplier added successfully!" type="success" />}
    {updated && <Toast id="updateToast" message="Supplier updated successfully!" type="success" />}
    {deleted && <Toast id="deleteToast" message="Supplier deleted successfully!" type="success" />}
    {error === 'used' && <Toast id="errorToast" message="Cannot delete: supplier has linked stock movements" type="error" duration={4000} />}

    <!-- Add Supplier Form (only if can edit) -->
    {canEdit && (
      <div class="bg-white dark:bg-ash-800 rounded-xl shadow-sm p-6 mb-6">
        <h2 class="text-xl font-semibold mb-4 text-ash-800 dark:text-white">Add New Supplier</h2>
        <form method="post" action="/api/add-supplier" class="space-y-4">
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <input
              type="text"
              name="name"
              placeholder="Supplier name"
              required
              class="border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white"
            />
            <input
              type="text"
              name="phone"
              placeholder="Phone"
              class="border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white"
            />
            <input
              type="email"
              name="email"
              placeholder="Email"
              class="border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white"
            />
          </div>
          <input
            type="text"
            name="address"
            placeholder="Address"
            class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white"
          />
          <button
            type="submit"
            class="bg-primary-500 text-white px-4 py-2 rounded-lg hover:bg-primary-600 transition"
          >
            Add Supplier
          </button>
        </form>
      </div>
    )}

    <!-- Suppliers Table (inline edit, horizontal scroll) -->
    <div class="bg-white dark:bg-ash-800 rounded-xl shadow-sm overflow-x-auto">
      <table class="w-full">
        <thead class="bg-ash-50 dark:bg-ash-700">
          <tr>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Name</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Phone</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Email</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Address</th>
            <th class="p-3 text-center text-ash-700 dark:text-ash-200">Actions</th>
          </tr>
        </thead>
        <tbody>
          {suppliers.map((s) => (
            <tr class="border-t border-ash-200 dark:border-ash-700" data-supplier-name={s.name}>
              <form method="post" action="/api/update-supplier" class="inline-flex gap-1 items-center">
                <input type="hidden" name="id" value={s.id} />
                <td class="p-3">
                  <input
                    type="text"
                    name="name"
                    value={s.name}
                    class="w-32 border border-ash-300 dark:border-ash-600 rounded-lg px-2 py-1 dark:bg-ash-800 dark:text-white"
                    required
                    disabled={!canEdit}
                  />
                </td>
                <td class="p-3">
                  <input
                    type="text"
                    name="phone"
                    value={s.phone || ''}
                    class="w-32 border border-ash-300 dark:border-ash-600 rounded-lg px-2 py-1 dark:bg-ash-800 dark:text-white"
                    disabled={!canEdit}
                  />
                </td>
                <td class="p-3">
                  <input
                    type="email"
                    name="email"
                    value={s.email || ''}
                    class="w-32 border border-ash-300 dark:border-ash-600 rounded-lg px-2 py-1 dark:bg-ash-800 dark:text-white"
                    disabled={!canEdit}
                  />
                </td>
                <td class="p-3">
                  <input
                    type="text"
                    name="address"
                    value={s.address || ''}
                    class="w-48 border border-ash-300 dark:border-ash-600 rounded-lg px-2 py-1 dark:bg-ash-800 dark:text-white"
                    disabled={!canEdit}
                  />
                </td>
                <td class="p-3 text-center">
                  <div class="flex gap-2 justify-center">
                    {canEdit && (
                      <>
                        <button type="submit" class="bg-primary-500 text-white px-2 py-1 rounded text-sm hover:bg-primary-600 transition">Save</button>
                        <button type="button" class="del-btn bg-red-600 text-white px-2 py-1 rounded text-sm hover:bg-red-700 transition" data-id={s.id} data-name={s.name}>Del</button>
                      </>
                    )}
                  </div>
                </td>
              </form>
            </tr>
          ))}
          {suppliers.length === 0 && (
            <tr>
              <td colspan="5" class="p-4 text-center text-ash-500 dark:text-ash-400">No suppliers yet.</td>
            </tr>
          )}
        </tbody>
      </table>
    </div>
  </div>

  <ConfirmModal />

  <script lang="js">
    document.querySelectorAll('.del-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const id = btn.getAttribute('data-id');
        const name = btn.getAttribute('data-name');
        const confirmed = await window.showConfirmModal({
          title: 'Delete Supplier',
          message: `Delete supplier "${name}"? This action cannot be undone.`
        });
        if (confirmed) {
          const form = document.createElement('form');
          form.method = 'POST';
          form.action = '/api/delete-supplier';
          const input = document.createElement('input');
          input.type = 'hidden';
          input.name = 'id';
          input.value = id;
          form.appendChild(input);
          document.body.appendChild(form);
          form.submit();
        }
      });
    });
  </script>
</AdminLayout>