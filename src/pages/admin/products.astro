---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import { db, rawDb } from '../../db';
import { products, categories, suppliers } from '../../db/schema';
import { eq } from 'drizzle-orm';
import ConfirmModal from '../../components/ConfirmModal.astro';
import Toast from '../../components/Toast.astro';

const allProducts = await db.select().from(products);
const allCategories = await db.select().from(categories);
const allSuppliers = await db.select().from(suppliers);
---

<AdminLayout>
  {Astro.url.searchParams.has('sold') && (
    <Toast id="quickSellToast" message="Sale recorded successfully!" type="success" />
  )}
  <div class="p-4 max-w-full overflow-x-auto">
    <div class="flex justify-between items-center mb-6">
      <h1 class="text-2xl font-bold">Manage Products</h1>
      <a href="/admin/dashboard" class="text-blue-600">← Dashboard</a>
    </div>

    <!-- Add Product Form  -->
    <div class="bg-white p-4 rounded shadow mb-8">
      <h2 class="text-xl font-semibold mb-3">Add New Product</h2>
      <form method="post" action="/api/create-product">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-3">
          <input type="text" name="name" placeholder="Product name" required class="border p-2 rounded" />
          <input type="number" step="0.01" name="price" placeholder="Selling price" required class="border p-2 rounded" />
          <input type="number" step="0.01" name="costPrice" placeholder="Cost price (total)" class="border p-2 rounded" />
          <input type="number" step="0.01" name="stock" placeholder="Stock" class="border p-2 rounded" />
          <input type="number" step="1" name="minStock" value="5" placeholder="Min stock alert" class="border p-2 rounded" />
          <select name="unit" class="border p-2 rounded">
            <option value="piece">piece</option>
            <option value="kg">kg</option>
            <option value="g">g</option>
            <option value="L">L</option>
            <option value="ml">ml</option>
          </select>
          <select name="categoryId" class="border p-2 rounded">
            <option value="">Select category</option>
            {allCategories.map(cat => <option value={cat.id}>{cat.name}</option>)}
          </select>
          <select name="supplierId" class="border p-2 rounded">
            <option value="">Select supplier</option>
            {allSuppliers.map(sup => <option value={sup.id}>{sup.name}</option>)}
          </select>
          <input type="text" name="imageUrl" placeholder="Image URL (optional)" class="border p-2 rounded" />
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-3">
          <label class="flex items-center gap-2">
            <input type="checkbox" name="onPromotion" value="1" class="w-5 h-5" />
            <span>On Promotion</span>
          </label>
          <input type="number" step="0.01" name="promoPrice" placeholder="Promotional price (optional)" class="border p-2 rounded" />
        </div>
        <button type="submit" class="mt-3 bg-green-600 text-white px-4 py-2 rounded">Add Product</button>
      </form>
    </div>

    <!-- Products Table -->
    <div class="bg-white rounded shadow overflow-x-auto">
      <table class="w-full min-w-[1000px]">
        <thead class="bg-gray-100">
          <tr>
            <th class="p-3 text-left">Name</th>
            <th class="p-3 text-left">Price/Promo</th>
            <th class="p-3 text-left">Cost</th>
            <th class="p-3 text-left">Stock</th>
            <th class="p-3 text-left">Min Stock</th>
            <th class="p-3 text-left">Unit</th>
            <th class="p-3 text-left">Category</th>
            <th class="p-3 text-left">Supplier</th>
            <th class="p-3 text-center">Actions</th>
            <th class="p-3 text-center">Quick Sell</th>
          </tr>
        </thead>
        <tbody>
          {allProducts.map(product => {
            const cat = allCategories.find(c => c.id === product.categoryId);
            const sup = allSuppliers.find(s => s.id === product.supplierId);
            const hasPromo = product.onPromotion && product.promoPrice && product.promoPrice < product.price;
            const isDeleted = !product.active;
            return (
              <tr class={`border-t ${isDeleted ? 'bg-gray-100 opacity-75' : ''}`} data-product-id={product.id}>
                <td class="p-3">
                  {product.name}
                  {isDeleted && <span class="ml-2 text-xs bg-red-100 text-red-700 px-2 py-0.5 rounded">DELETED</span>}
                </td>
                <td class="p-3">
                  {hasPromo ? (
                    <><span class="line-through text-gray-500">Tsh {product.price}</span> → <span class="text-red-600 font-bold">Tsh {product.promoPrice}</span></>
                  ) : (
                    `Tsh ${product.price}`
                  )}
                </td>
                <td class="p-3">{product.costPrice ? `Tsh ${product.costPrice}` : '-'}</td>
                <td class="p-3">
                  <span class="stock-cell stock-value" data-product-id={product.id}>{product.stock}</span> {product.unit || 'piece'}
                </td>
                <td class="p-3">
                  <input type="number" step="1" name="minStock" value={product.minStock || 5} class="border p-1 w-16 text-sm" disabled={isDeleted} />
                </td>
                <td class="p-3">{product.unit || 'piece'}</td>
                <td class="p-3">{cat?.name || '-'}</td>
                <td class="p-3">{sup?.name || '-'}</td>
                <td class="p-3 text-center">
                  <div class="flex gap-2 justify-center flex-wrap">
                    <!-- Inline edit form (disabled when product is deleted) -->
                    <form method="post" action="/api/update-product" class="inline-flex gap-1 flex-wrap">
                      <input type="hidden" name="id" value={product.id} />
                      <input type="hidden" name="active" value="1" />
                      <input type="text" name="name" value={product.name} class="border p-1 w-24 text-sm" required disabled={isDeleted} />
                      <input type="number" step="0.01" name="price" value={product.price} class="border p-1 w-20 text-sm" required disabled={isDeleted} />
                      <input type="number" step="0.01" name="costPrice" value={product.costPrice || ''} class="border p-1 w-20 text-sm" placeholder="cost" disabled={isDeleted} />
                      <input type="number" step="0.01" name="stock" value={product.stock} class="border p-1 w-16 text-sm" disabled={isDeleted} />
                      <input type="number" step="1" name="minStock" value={product.minStock || 5} class="border p-1 w-16 text-sm" disabled={isDeleted} />
                      <select name="unit" class="border p-1 text-sm" disabled={isDeleted}>
                        <option value="piece" selected={product.unit === 'piece'}>piece</option>
                        <option value="kg" selected={product.unit === 'kg'}>kg</option>
                        <option value="g" selected={product.unit === 'g'}>g</option>
                        <option value="L" selected={product.unit === 'L'}>L</option>
                        <option value="ml" selected={product.unit === 'ml'}>ml</option>
                      </select>
                      <select name="categoryId" class="border p-1 text-sm" disabled={isDeleted}>
                        <option value="">None</option>
                        {allCategories.map(cat => (
                          <option value={cat.id} selected={cat.id === product.categoryId}>{cat.name}</option>
                        ))}
                      </select>
                      <select name="supplierId" class="border p-1 text-sm" disabled={isDeleted}>
                        <option value="">None</option>
                        {allSuppliers.map(sup => (
                          <option value={sup.id} selected={sup.id === product.supplierId}>{sup.name}</option>
                        ))}
                      </select>
                      <span class="flex items-center gap-1">
                        <input type="checkbox" name="onPromotion" value="1" class="w-4 h-4" checked={product.onPromotion} disabled={isDeleted} />
                        <label class="text-xs">Promo</label>
                      </span>
                      <input type="number" step="0.01" name="promoPrice" value={product.promoPrice || ''} placeholder="Promo price" class="border p-1 w-20 text-sm" disabled={isDeleted} />
                      {!isDeleted && <button type="submit" class="bg-blue-600 text-white px-2 py-1 rounded text-sm">Save</button>}
                    </form>
                    <!-- Delete/Restore buttons -->
                    {!isDeleted ? (
                      <button type="button" class="delete-product-btn bg-red-600 text-white px-2 py-1 rounded text-sm" data-id={product.id} data-name={product.name}>Del</button>
                    ) : (
                    <form method="post" action="/api/restore-product" class="inline">
                    <input type="hidden" name="id" value={product.id} />
                    <button type="submit" class="bg-green-600 text-white px-2 py-1 rounded text-sm">Restore</button>
                    </form>
                    )}
                  </div>
                </td>
                <td class="p-3 text-center">
                  <form method="post" action="/api/quick-sell" class="inline-flex gap-1 items-center">
                    <input type="hidden" name="productId" value={product.id} />
                    <input type="hidden" name="usePromo" value="1" />
                    <input type="number" name="quantity" value="1" step="1" min="1" class="border p-1 w-16 text-sm" required disabled={isDeleted} />
                    <button type="submit" class="quick-sell-btn bg-green-600 text-white px-2 py-1 rounded text-sm" disabled={isDeleted}>Sell</button>
                  </form>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    <div class="mt-4 text-sm text-gray-600">
      <a href="/admin/categories" class="text-blue-600">Manage Categories</a> |
      <a href="/admin/suppliers" class="text-blue-600">Manage Suppliers</a>
    </div>
  </div>

  <!-- Real-time stock updates via global SSE -->
  <script lang="js">
    window.addEventListener('sse:stock-update', (event) => {
      const update = event.detail;
      const stockSpan = document.querySelector(`.stock-value[data-product-id="${update.productId}"]`);
      if (stockSpan) {
        stockSpan.innerText = update.stock;
        const row = stockSpan.closest('tr');
        if (row) {
          const sellBtn = row.querySelector('.quick-sell-btn');
          if (sellBtn) {
            sellBtn.disabled = (update.stock <= 0);
            if (sellBtn.disabled) sellBtn.classList.add('opacity-50', 'cursor-not-allowed');
            else sellBtn.classList.remove('opacity-50', 'cursor-not-allowed');
          }
        }
      }
    });
    window.addEventListener('sse:category-created', () => { location.reload(); });
    window.addEventListener('sse:category-deleted', () => { location.reload(); });
  </script>

  <!-- Delete confirmation modal script -->
  <script lang="js">
    document.querySelectorAll('.delete-product-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const id = btn.getAttribute('data-id');
        const name = btn.getAttribute('data-name');
        const confirmed = await window.showConfirmModal({
          title: 'Delete Product',
          message: `Delete product "${name}"? This will soft‑delete it (hide from store).`
        });
        if (confirmed) {
          const form = document.createElement('form');
          form.method = 'POST';
          form.action = '/api/delete-product';
          const input = document.createElement('input');
          input.type = 'hidden';
          input.name = 'id';
          input.value = id;
          form.appendChild(input);
          document.body.appendChild(form);
          form.submit();
        }
      });
    });
  </script>

  <ConfirmModal />
</AdminLayout>