---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { db, rawDb } from "../../db";
import { products, categories, suppliers } from "../../db/schema";
import ConfirmModal from "../../components/ConfirmModal.astro";
import Toast from "../../components/Toast.astro";
import BarcodeScanner from "../../components/BarcodeScanner.astro";
import AddProductModal from "../../components/AddProductModal.astro";
import EditProductModal from "../../components/EditProductModal.astro";

const { user, permissions } = Astro.locals;
const canEdit = permissions?.includes("products.edit") ?? false;
const canSell = permissions?.includes("sales.create") ?? false;

const search = Astro.url.searchParams.get("search") || "";

// Build SQL with search filter
let sql = "SELECT * FROM products";
let params: string[] = [];
if (search) {
  sql += " WHERE (name LIKE ? OR sku LIKE ? OR barcode LIKE ?)";
  const like = `%${search}%`;
  params = [like, like, like];
}
sql += " ORDER BY id DESC";
const allProducts = rawDb.prepare(sql).all(...params) as any[];

const allCategories = await db.select().from(categories);
const allSuppliers = await db.select().from(suppliers);
---

<AdminLayout>
  {Astro.url.searchParams.has("sold") && (
    <Toast id="quickSellToast" message="Sale recorded successfully!" type="success" />
  )}
  <div class="p-4">
    <!-- Search & Barcode Scan (unchanged) -->
    <div class="bg-white dark:bg-ash-800 rounded-xl shadow-sm p-4 mb-6">
      <div class="flex flex-wrap gap-2 items-center">
        <form method="get" class="flex-1 flex gap-2">
          <input
            type="text"
            name="search"
            value={search}
            placeholder="Search by name, SKU, or barcode"
            class="flex-1 border border-ash-300 dark:border-ash-600 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary-500 dark:bg-ash-800 dark:text-white"
          />
          <button type="submit" class="bg-primary-500 text-white px-4 py-2 rounded-lg hover:bg-primary-600 transition">Search</button>
          <button type="button" id="scanSearchBtn" class="bg-secondary-500 text-white px-4 py-2 rounded-lg hover:bg-secondary-600 transition">Scan Barcode</button>
          {search && (
            <a href="/admin/products" class="bg-ash-500 text-white px-4 py-2 rounded-lg hover:bg-ash-600 transition">Clear</a>
          )}
        </form>
        {canEdit && (
          <button id="openAddProductBtn" class="bg-primary-500 text-white px-4 py-2 rounded-lg hover:bg-primary-600 transition">+ Add Product</button>
        )}
      </div>
    </div>

    <!-- Products Table (fixed: no forced min-width, just overflow-auto) -->
    <div class="bg-white dark:bg-ash-800 rounded-xl shadow-sm overflow-x-auto">
      <table class="w-full">
        <thead class="bg-ash-50 dark:bg-ash-700">
          <tr>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Name</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">SKU</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Barcode</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Price/Promo</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Cost</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Stock</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Min Stock</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Unit</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Bulk Unit</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Bulk Factor</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Category</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Supplier</th>
            <th class="p-3 text-center text-ash-700 dark:text-ash-200">Actions</th>
            <th class="p-3 text-center text-ash-700 dark:text-ash-200">Quick Sell</th>
          </tr>
        </thead>
        <tbody>
          {allProducts.map((product) => {
            const cat = allCategories.find((c) => c.id === product.category_id);
            const sup = allSuppliers.find((s) => s.id === product.supplier_id);
            const hasPromo = product.on_promotion && product.promo_price && product.promo_price < product.price;
            const isDeleted = !product.active;
            return (
              <tr class={`border-t border-ash-200 dark:border-ash-700 ${isDeleted ? "bg-ash-100 dark:bg-ash-700/50 opacity-75" : ""}`} data-product-id={product.id}>
                <td class="p-3 dark:text-ash-200">{product.name}{isDeleted && <span class="ml-2 text-xs bg-red-100 red-700 dark:bg-red-900 dark:text-red-300 px-2 py-0.5 rounded">DELETED</span>}</td>
                <td class="p-3 dark:text-ash-200">{product.sku || "-"}</td>
                <td class="p-3 dark:text-ash-200">{product.barcode || "-"}</td>
                <td class="p-3 dark:text-ash-200">
                  {hasPromo ? (
                    <><span class="line-through text-gray-500 dark:text-gray-400">Tsh {product.price}</span> → <span class="text-red-600 dark:text-red-400 font-bold">Tsh {product.promo_price}</span></>
                  ) : (
                    `Tsh ${product.price}`
                  )}
                </td>
                <td class="p-3 dark:text-ash-200">{product.cost_price ? `Tsh ${product.cost_price}` : "-"}</td>
                <td class="p-3 dark:text-ash-200"><span class="stock-cell stock-value" data-product-id={product.id}>{product.stock}</span> {product.unit || "piece"}</td>
                <td class="p-3 dark:text-ash-200">{product.min_stock || 5}</td>
                <td class="p-3 dark:text-ash-200">{product.unit || "piece"}</td>
                <td class="p-3 dark:text-ash-200">{product.bulk_unit || "-"}</td>
                <td class="p-3 dark:text-ash-200">{product.bulk_factor || 1}</td>
                <td class="p-3 dark:text-ash-200">{cat?.name || "-"}</td>
                <td class="p-3 dark:text-ash-200">{sup?.name || "-"}</td>
                <td class="p-3 text-center">
                  <div class="flex gap-2 justify-center flex-wrap">
                    {canEdit && (
                      <>
                        <button type="button" class="edit-product-btn bg-primary-500 text-white px-2 py-1 rounded text-sm" data-product={JSON.stringify(product)}>Edit</button>
                        {!isDeleted ? (
                          <button type="button" class="delete-product-btn bg-red-600 text-white px-2 py-1 rounded text-sm" data-id={product.id} data-name={product.name}>Del</button>
                        ) : (
                          <form method="post" action="/api/restore-product" class="inline">
                            <input type="hidden" name="id" value={product.id} />
                            <button type="submit" class="bg-green-600 text-white px-2 py-1 rounded text-sm">Restore</button>
                          </form>
                        )}
                      </>
                    )}
                  </div>
                </td>
                <td class="p-3 text-center">
                  {canSell && (
                    <form method="post" action="/api/quick-sell" class="inline-flex gap-1 items-center">
                      <input type="hidden" name="productId" value={product.id} />
                      <input type="hidden" name="usePromo" value="1" />
                      <input type="number" name="quantity" value="1" step="1" min="1" class="border border-ash-300 dark:border-ash-600 rounded px-2 py-1 w-16 text-sm" required />
                      <button type="submit" class="quick-sell-btn bg-secondary-500 text-white px-2 py-1 rounded text-sm">Sell</button>
                    </form>
                  )}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    <div class="mt-4 text-sm text-ash-500 dark:text-ash-400">
      <a href="/admin/categories" class="text-primary-600 dark:text-primary-400 hover:underline">Manage Categories</a> |
      <a href="/admin/suppliers" class="text-primary-600 dark:text-primary-400 hover:underline">Manage Suppliers</a>
    </div>
  </div>

  <!-- Modals (unchanged) -->
  <AddProductModal categories={allCategories} suppliers={allSuppliers} />
  <EditProductModal categories={allCategories} suppliers={allSuppliers} />

  <!-- Real-time stock updates via global SSE (unchanged) -->
  <script lang="js">
    window.addEventListener("sse:stock-update", (event) => {
      const update = event.detail;
      const stockSpan = document.querySelector(`.stock-value[data-product-id="${update.productId}"]`);
      if (stockSpan) {
        stockSpan.innerText = update.stock;
        const row = stockSpan.closest("tr");
        if (row) {
          const sellBtn = row.querySelector(".quick-sell-btn");
          if (sellBtn) {
            sellBtn.disabled = update.stock <= 0;
            if (sellBtn.disabled) sellBtn.classList.add("opacity-50", "cursor-not-allowed");
            else sellBtn.classList.remove("opacity-50", "cursor-not-allowed");
          }
        }
      }
    });
    window.addEventListener("sse:category-created", () => { location.reload(); });
    window.addEventListener("sse:category-deleted", () => { location.reload(); });
  </script>

  <script lang="js">
    // Delete confirmation modal script
    document.querySelectorAll(".delete-product-btn").forEach((btn) => {
      btn.addEventListener("click", async (e) => {
        e.stopPropagation();
        const id = btn.getAttribute("data-id");
        const name = btn.getAttribute("data-name");
        const confirmed = await window.showConfirmModal({
          title: "Delete Product",
          message: `Delete product "${name}"? This will soft‑delete it (hide from store).`,
        });
        if (confirmed) {
          const form = document.createElement("form");
          form.method = "POST";
          form.action = "/api/delete-product";
          const input = document.createElement("input");
          input.type = "hidden";
          input.name = "id";
          input.value = id;
          form.appendChild(input);
          document.body.appendChild(form);
          form.submit();
        }
      });
    });

    // Open add product modal
    const addBtn = document.getElementById("openAddProductBtn");
    if (addBtn && window.showAddProductModal) {
      addBtn.addEventListener("click", () => window.showAddProductModal());
    }

    // Open edit product modal
    document.querySelectorAll(".edit-product-btn").forEach((btn) => {
      btn.addEventListener("click", () => {
        const productData = JSON.parse(btn.getAttribute("data-product"));
        if (window.showEditProductModal) {
          window.showEditProductModal(productData);
        }
      });
    });

    // Barcode scanner integration for search
    const scanBtn = document.getElementById("scanSearchBtn");
    if (scanBtn) {
      scanBtn.addEventListener("click", () => {
        window.showBarcodeScanner(async (code) => {
          window.location.href = `/admin/products?search=${encodeURIComponent(code)}`;
        });
      });
    }
  </script>

  <BarcodeScanner />
  <ConfirmModal />
</AdminLayout>