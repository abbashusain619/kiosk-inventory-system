---
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import ConfirmModal from '../../components/ConfirmModal.astro';
import Toast from '../../components/Toast.astro';
import { rawDb } from '../../db';

const { permissions } = Astro.locals;
const canEdit = permissions?.includes('categories.edit') ?? false;

const added = Astro.url.searchParams.has('added');
const deleted = Astro.url.searchParams.has('deleted');
const error = Astro.url.searchParams.get('error');

const categories = rawDb.prepare('SELECT id, name FROM categories ORDER BY name').all() as { id: number; name: string }[];
---

<AdminLayout>
  <div class="p-4 max-w-2xl mx-auto">
    <!-- Toasts -->
    {added && <Toast id="addToast" message="Category added successfully!" type="success" />}
    {deleted && <Toast id="deleteToast" message="Category deleted successfully!" type="success" />}
    {error === 'used' && <Toast id="errorToast" message="Cannot delete: category is used by products" type="error" duration={4000} />}

    <!-- Add Category Form (only if user has edit permission) -->
    {canEdit && (
      <div class="bg-white dark:bg-ash-800 rounded-xl shadow-sm p-4 mb-6">
        <form method="post" action="/api/add-category" class="flex gap-2">
          <input
            type="text"
            name="name"
            placeholder="New category name"
            required
            class="flex-1 border border-ash-300 dark:border-ash-600 rounded-lg px-4 py-2 focus:ring-2 focus:ring-primary-500 dark:bg-ash-800 dark:text-white"
          />
          <button
            type="submit"
            class="bg-primary-500 text-white px-4 py-2 rounded-lg hover:bg-primary-600 transition"
          >
            Add Category
          </button>
        </form>
      </div>
    )}

    <!-- Categories List -->
    <div class="bg-white dark:bg-ash-800 rounded-xl shadow-sm overflow-hidden">
      <ul class="divide-y divide-ash-200 dark:divide-ash-700">
        {categories.map((cat) => (
          <li class="p-4 flex justify-between items-center">
            <span class="text-ash-800 dark:text-ash-200">{cat.name}</span>
            {canEdit && (
              <button
                type="button"
                class="delete-category-btn text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300 transition"
                data-id={cat.id}
                data-name={cat.name}
              >
                Delete
              </button>
            )}
          </li>
        ))}
        {categories.length === 0 && (
          <li class="p-4 text-center text-ash-500 dark:text-ash-400">No categories yet.</li>
        )}
      </ul>
    </div>
  </div>

  <ConfirmModal />

  <script lang="js">
    document.querySelectorAll('.delete-category-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const id = btn.getAttribute('data-id');
        const name = btn.getAttribute('data-name');
        const confirmed = await window.showConfirmModal({
          title: 'Delete Category',
          message: `Delete category "${name}"? Products using it will lose category assignment.`,
        });
        if (confirmed) {
          const form = document.createElement('form');
          form.method = 'POST';
          form.action = '/api/delete-category';
          const input = document.createElement('input');
          input.type = 'hidden';
          input.name = 'id';
          input.value = id;
          form.appendChild(input);
          document.body.appendChild(form);
          form.submit();
        }
      });
    });
  </script>
</AdminLayout>