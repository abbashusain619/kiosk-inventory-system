---
export const prerender = false;
import AdminLayout from "../../layouts/AdminLayout.astro";
import { rawDb } from "../../db";
import BarcodeScanner from "../../components/BarcodeScanner.astro";

const { permissions } = Astro.locals;
const canView = permissions?.includes("stock.view") ?? false;
const canIn = permissions?.includes("stock.in") ?? false;
const canAdjust = permissions?.includes("stock.adjust") ?? false;
const canRecord = canIn || canAdjust;
const canAddProduct = permissions?.includes("products.edit") ?? false;
const canAddSupplier = permissions?.includes("suppliers.edit") ?? false;

if (!canView) {
  return Astro.redirect("/admin/dashboard");
}

// Fetch movements
const movements = rawDb
  .prepare(
    `
  SELECT sm.*, p.name as product_name 
  FROM stock_movements sm
  JOIN products p ON sm.product_id = p.id
  ORDER BY sm.created_at DESC
  LIMIT 200
`,
  )
  .all() as any[];

const products = rawDb
  .prepare("SELECT id, name FROM products WHERE active = 1 ORDER BY name")
  .all() as { id: number; name: string }[];
const suppliers = rawDb
  .prepare("SELECT id, name FROM suppliers ORDER BY name")
  .all() as { id: number; name: string }[];
const categories = rawDb
  .prepare("SELECT id, name FROM categories ORDER BY name")
  .all() as { id: number; name: string }[];
---

<AdminLayout>
  <div class="p-4">
    <!-- Refresh button row (no title – handled by top bar) -->
    <div class="flex justify-end mb-4">
      <button
        id="refreshBtn"
        class="bg-primary-500 text-white px-4 py-2 rounded-lg hover:bg-primary-600 transition text-sm"
      >
        Refresh
      </button>
    </div>

    <!-- Record Movement Form -->
{canRecord && (
  <div class="bg-white dark:bg-ash-800 rounded-xl shadow-sm p-6 mb-6">
    <h2 class="text-xl font-semibold mb-4 text-ash-800 dark:text-white">Add Movement</h2>
    <form method="post" action="/api/add-movement" id="movementForm" class="space-y-5">
      <!-- Row 1: Product selection + barcode row -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <!-- Product select -->
        <div>
          <label class="block text-sm font-medium text-ash-700 dark:text-ash-300 mb-1">Product</label>
          <select
            name="productId"
            id="productSelect"
            required
            class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white"
          >
            <option value="">Select product</option>
            {products.map((p) => (
              <option value={p.id}>{p.name}</option>
            ))}
          </select>
        </div>

        <!-- Barcode input + lookup + scan -->
        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-ash-700 dark:text-ash-300 mb-1">Barcode / SKU</label>
          <div class="flex gap-2">
            <input
              type="text"
              id="barcodeInput"
              placeholder="Scan or type barcode/SKU"
              class="flex-1 border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white"
            />
            <button
              type="button"
              id="lookupBarcodeBtn"
              class="bg-primary-500 text-white px-4 py-2 rounded-lg hover:bg-primary-600 transition"
            >
              Lookup
            </button>
            <button
              type="button"
              id="scanBarcodeTransactionsBtn"
              class="bg-secondary-500 text-white px-4 py-2 rounded-lg hover:bg-secondary-600 transition"
            >
              Scan
            </button>
          </div>
          {canAddProduct && (
            <button
              type="button"
              id="quickAddProductBtn"
              class="text-primary-600 dark:text-primary-400 text-sm underline mt-1"
            >
              + New Product
            </button>
          )}
        </div>
      </div>

      <!-- Row 2: Movement type, quantity + unit, total cost -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <!-- Movement type -->
        <div>
          <label class="block text-sm font-medium text-ash-700 dark:text-ash-300 mb-1">Movement Type</label>
          <select name="type" id="movementType" required class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white">
            {canIn && <option value="in">Purchase (Stock In)</option>}
            {canAdjust && <option value="adjustment">Adjustment</option>}
            {canAdjust && <option value="cost_correction">Cost Correction (adjust cost only)</option>}
          </select>
        </div>

        <!-- Quantity + Unit -->
        <div>
          <label class="block text-sm font-medium text-ash-700 dark:text-ash-300 mb-1">Quantity &amp; Unit</label>
          <div class="flex gap-2">
            <input
              type="number"
              step="0.01"
              name="quantity"
              id="quantityInput"
              placeholder="Quantity"
              required
              class="flex-1 border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white"
            />
            <select id="unitSelect" class="w-32 border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white">
              <option value="base">piece</option>
            </select>
          </div>
        </div>

        <!-- Total cost (visible for purchase) -->
        <div id="totalCostContainer">
          <label class="block text-sm font-medium text-ash-700 dark:text-ash-300 mb-1">Total Cost (Tsh)</label>
          <input
            type="number"
            step="0.01"
            name="totalCost"
            id="totalCostInput"
            placeholder="For purchase"
            class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white"
          />
        </div>

        <!-- New cost (visible for cost correction) -->
        <div id="newCostContainer" style="display: none;">
          <label class="block text-sm font-medium text-ash-700 dark:text-ash-300 mb-1">New Cost per Unit (Tsh)</label>
          <input
            type="number"
            step="0.01"
            name="newCost"
            id="newCostInput"
            placeholder="New cost per unit"
            class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white"
          />
        </div>
      </div>

      <!-- Row 3: Supplier + Reason -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-ash-700 dark:text-ash-300 mb-1">Supplier (optional)</label>
          <div class="relative">
            <select
              name="supplierId"
              id="supplierSelect"
              class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white"
            >
              <option value="">Select supplier</option>
              {suppliers.map((s) => (
                <option value={s.id}>{s.name}</option>
              ))}
            </select>
            {canAddSupplier && (
              <button
                type="button"
                id="quickAddSupplierBtn"
                class="text-primary-600 dark:text-primary-400 text-sm underline mt-1"
              >
                + New Supplier
              </button>
            )}
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-ash-700 dark:text-ash-300 mb-1">Reason</label>
          <input
            type="text"
            name="reason"
            placeholder="e.g., purchase, spoilage"
            class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white"
          />
        </div>
      </div>

      <button
        type="submit"
        class="bg-primary-500 text-white px-5 py-2 rounded-lg hover:bg-primary-600 transition shadow-sm"
      >
        Record Movement
      </button>
    </form>
  </div>
)}
    <!-- Movements Table (horizontal scroll) -->
    <div class="bg-white dark:bg-ash-800 rounded-xl shadow-sm overflow-x-auto">
      <table class="w-full">
        <thead class="bg-ash-50 dark:bg-ash-700">
          <tr>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Date</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Product</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Type</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Quantity</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Total (Tsh)</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">Reason</th>
            <th class="p-3 text-left text-ash-700 dark:text-ash-200">User</th>
          </tr>
        </thead>
        <tbody>
          {movements.map((m) => (
            <tr class="border-t border-ash-200 dark:border-ash-700">
              <td class="p-3 dark:text-ash-200">{new Date(m.created_at).toLocaleString()}</td>
              <td class="p-3 dark:text-ash-200">{m.product_name}</td>
              <td class="p-3 dark:text-ash-200">{m.type}</td>
              <td class="p-3 dark:text-ash-200">{m.quantity}</td>
              <td class="p-3 dark:text-ash-200">{m.total_price || m.total_cost || "-"}</td>
              <td class="p-3 dark:text-ash-200">{m.reason || "-"}</td>
              <td class="p-3 dark:text-ash-200">{m.user_id}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Modals (same as before, but with dark mode classes – I'll update them for consistency) -->
  <!-- Quick Add Product Modal -->
  <div
    id="productModal"
    class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50"
  >
    <div class="bg-white dark:bg-ash-800 rounded-xl shadow-xl max-w-md w-full p-6">
      <h3 class="text-lg font-semibold mb-4 text-ash-800 dark:text-white">Add New Product</h3>
      <form id="quickProductForm" class="space-y-3">
        <div>
          <label class="block text-sm font-medium text-ash-700 dark:text-ash-300">Product Name *</label>
          <input type="text" id="prodName" required class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white" />
        </div>
        <div>
          <label class="block text-sm font-medium text-ash-700 dark:text-ash-300">Selling Price *</label>
          <input type="number" step="0.01" id="prodPrice" required class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white" />
        </div>
        <div>
          <label class="block text-sm font-medium text-ash-700 dark:text-ash-300">Unit</label>
          <select id="prodUnit" class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white">
            <option value="piece">piece</option><option value="kg">kg</option><option value="g">g</option><option value="L">L</option><option value="ml">ml</option>
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-ash-700 dark:text-ash-300">Bulk Unit (optional)</label>
          <input type="text" id="prodBulkUnit" placeholder="e.g., carton" class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white" />
        </div>
        <div>
          <label class="block text-sm font-medium text-ash-700 dark:text-ash-300">Bulk Factor (optional)</label>
          <input type="number" step="0.01" id="prodBulkFactor" placeholder="e.g., 12" class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white" value="1" />
        </div>
        <div>
          <label class="block text-sm font-medium text-ash-700 dark:text-ash-300">Category (optional)</label>
          <input type="text" id="prodCategory" list="categoryOptions" class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white" />
          <datalist id="categoryOptions">
            {categories.map((c) => <option value={c.name} />)}
          </datalist>
        </div>
        <div class="flex justify-end gap-2 pt-2">
          <button type="button" id="closeProductModal" class="bg-gray-400 dark:bg-ash-700 text-white px-4 py-2 rounded-lg">Cancel</button>
          <button type="submit" class="bg-primary-500 text-white px-4 py-2 rounded-lg hover:bg-primary-600 transition">Create Product</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Quick Add Supplier Modal -->
  <div
    id="supplierModal"
    class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50"
  >
    <div class="bg-white dark:bg-ash-800 rounded-xl shadow-xl max-w-md w-full p-6">
      <h3 class="text-lg font-semibold mb-4 text-ash-800 dark:text-white">Add New Supplier</h3>
      <form id="quickSupplierForm" class="space-y-3">
        <div>
          <label class="block text-sm font-medium text-ash-700 dark:text-ash-300">Supplier Name *</label>
          <input type="text" id="supName" required class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white" />
        </div>
        <div>
          <label class="block text-sm font-medium text-ash-700 dark:text-ash-300">Phone (optional)</label>
          <input type="text" id="supPhone" class="w-full border border-ash-300 dark:border-ash-600 rounded-lg px-3 py-2 dark:bg-ash-800 dark:text-white" />
        </div>
        <div class="flex justify-end gap-2 pt-2">
          <button type="button" id="closeSupplierModal" class="bg-gray-400 dark:bg-ash-700 text-white px-4 py-2 rounded-lg">Cancel</button>
          <button type="submit" class="bg-primary-500 text-white px-4 py-2 rounded-lg hover:bg-primary-600 transition">Create Supplier</button>
        </div>
      </form>
    </div>
  </div>

  <script lang="js">
    document.addEventListener("DOMContentLoaded", () => {
      // DOM elements (same as before, but using the new IDs)
      const productModal = document.getElementById("productModal");
      const supplierModal = document.getElementById("supplierModal");
      const quickProductBtn = document.getElementById("quickAddProductBtn");
      const quickSupplierBtn = document.getElementById("quickAddSupplierBtn");
      const closeProductModal = document.getElementById("closeProductModal");
      const closeSupplierModal = document.getElementById("closeSupplierModal");
      const productForm = document.getElementById("quickProductForm");
      const supplierForm = document.getElementById("quickSupplierForm");
      const productSelect = document.getElementById("productSelect");
      const supplierSelect = document.getElementById("supplierSelect");
      const refreshBtn = document.getElementById("refreshBtn");
      const barcodeInput = document.getElementById("barcodeInput");
      const lookupBtn = document.getElementById("lookupBarcodeBtn");
      const scanBtn = document.getElementById("scanBarcodeTransactionsBtn");
      const movementType = document.getElementById("movementType");
      const quantityInput = document.getElementById("quantityInput");
      const totalCostInput = document.getElementById("totalCostInput");
      const newCostInput = document.getElementById("newCostInput");
      const unitSelect = document.getElementById("unitSelect");

      let currentUnit = "piece";
      let currentBulkFactor = 1;
      let currentBulkUnit = null;

      function showModal(modal) { if (modal) { modal.classList.remove("hidden"); modal.classList.add("flex"); } }
      function hideModal(modal) { if (modal) { modal.classList.remove("flex"); modal.classList.add("hidden"); } }

      // Quick add product logic (unchanged)
      if (productForm) {
        productForm.addEventListener("submit", async (e) => {
          e.preventDefault();
          const name = document.getElementById("prodName").value;
          const price = document.getElementById("prodPrice").value;
          const unit = document.getElementById("prodUnit").value;
          const bulkUnit = document.getElementById("prodBulkUnit").value;
          const bulkFactor = document.getElementById("prodBulkFactor").value;
          const category = document.getElementById("prodCategory").value;
          const fd = new FormData();
          fd.append("name", name);
          fd.append("price", price);
          fd.append("unit", unit);
          if (bulkUnit) fd.append("bulkUnit", bulkUnit);
          if (bulkFactor && bulkFactor !== "1") fd.append("bulkFactor", bulkFactor);
          if (category) fd.append("category", category);
          const res = await fetch("/api/quick-add-product", { method: "POST", body: fd });
          if (res.ok) {
            const newProduct = await res.json();
            const opt = document.createElement("option");
            opt.value = newProduct.id;
            opt.textContent = newProduct.name;
            if (productSelect) productSelect.appendChild(opt);
            if (productSelect) productSelect.value = newProduct.id;
            productSelect.dispatchEvent(new Event("change"));
            hideModal(productModal);
            productForm.reset();
            if (window.showToast) window.showToast("Product created!");
          } else {
            const err = await res.text();
            if (window.showToast) window.showToast(err, "error");
          }
        });
      }

      if (supplierForm) {
        supplierForm.addEventListener("submit", async (e) => {
          e.preventDefault();
          const name = document.getElementById("supName").value;
          const phone = document.getElementById("supPhone").value;
          const fd = new FormData();
          fd.append("name", name);
          if (phone) fd.append("phone", phone);
          const res = await fetch("/api/quick-add-supplier", { method: "POST", body: fd });
          if (res.ok) {
            const newSupplier = await res.json();
            const opt = document.createElement("option");
            opt.value = newSupplier.id;
            opt.textContent = newSupplier.name;
            if (supplierSelect) supplierSelect.appendChild(opt);
            if (supplierSelect) supplierSelect.value = newSupplier.id;
            hideModal(supplierModal);
            supplierForm.reset();
            if (window.showToast) window.showToast("Supplier created!");
          } else {
            const err = await res.text();
            if (window.showToast) window.showToast(err, "error");
          }
        });
      }

      if (quickProductBtn) quickProductBtn.addEventListener("click", () => showModal(productModal));
      if (closeProductModal) closeProductModal.addEventListener("click", () => hideModal(productModal));
      if (quickSupplierBtn) quickSupplierBtn.addEventListener("click", () => showModal(supplierModal));
      if (closeSupplierModal) closeSupplierModal.addEventListener("click", () => hideModal(supplierModal));

      async function loadProductUnits(productId) {
        if (!productId) return;
        const res = await fetch(`/api/product-unit?id=${productId}`);
        if (res.ok) {
          const data = await res.json();
          currentUnit = data.unit || "piece";
          currentBulkUnit = data.bulkUnit;
          currentBulkFactor = data.bulkFactor || 1;
          unitSelect.innerHTML = `<option value="base">${currentUnit}</option>`;
          if (currentBulkUnit) unitSelect.innerHTML += `<option value="bulk">${currentBulkUnit}</option>`;
        } else {
          unitSelect.innerHTML = `<option value="base">piece</option>`;
        }
      }

      productSelect.addEventListener("change", () => {
        const productId = productSelect.value;
        if (productId) loadProductUnits(productId);
        else unitSelect.innerHTML = `<option value="base">piece</option>`;
      });

      async function lookupProductByCode(code) {
        const res = await fetch(`/api/product-by-barcode?code=${encodeURIComponent(code)}`);
        if (res.ok) {
          const product = await res.json();
          productSelect.value = product.id;
          productSelect.dispatchEvent(new Event("change"));
          barcodeInput.value = "";
          if (window.showToast) window.showToast(`Product ${product.name} selected`, "success");
        } else {
          window.showToast("Product not found", "error");
        }
      }

      if (lookupBtn) lookupBtn.addEventListener("click", () => {
        const code = barcodeInput.value.trim();
        if (code) lookupProductByCode(code);
      });

      if (scanBtn) scanBtn.addEventListener("click", () => {
        window.showBarcodeScanner(async (code) => lookupProductByCode(code));
      });

      function toggleCostCorrectionFields() {
        const isCostCorrection = movementType.value === "cost_correction";
        if (isCostCorrection) {
          quantityInput.style.display = "none";
          unitSelect.style.display = "none";
          totalCostInput.style.display = "none";
          newCostInput.style.display = "block";
          quantityInput.required = false;
          totalCostInput.required = false;
          newCostInput.required = true;
        } else {
          quantityInput.style.display = "block";
          unitSelect.style.display = "block";
          totalCostInput.style.display = "block";
          newCostInput.style.display = "none";
          quantityInput.required = true;
          totalCostInput.required = false;
          newCostInput.required = false;
        }
      }
      if (movementType) {
        movementType.addEventListener("change", toggleCostCorrectionFields);
        toggleCostCorrectionFields();
      }

      const movementForm = document.getElementById("movementForm");
      if (movementForm) {
        movementForm.addEventListener("submit", (e) => {
          const selectedUnit = unitSelect.value;
          let rawQuantity = parseFloat(quantityInput.value);
          if (isNaN(rawQuantity)) rawQuantity = 0;
          let baseQuantity = rawQuantity;
          if (selectedUnit === "bulk" && currentBulkUnit && currentBulkFactor > 0) {
            baseQuantity = rawQuantity * currentBulkFactor;
          }
          quantityInput.value = baseQuantity;
        });
      }

      window.addEventListener("click", (e) => {
        if (e.target === productModal) hideModal(productModal);
        if (e.target === supplierModal) hideModal(supplierModal);
      });

      if (refreshBtn) refreshBtn.addEventListener("click", () => window.location.reload());
    });
  </script>
  <BarcodeScanner />
</AdminLayout>