---
import Layout from './Layout.astro';
const { user, permissions } = Astro.locals;
if (!user) {
  return Astro.redirect('/admin/login');
}
const canManageUsers = permissions?.includes('users.manage') ?? false;
const canManageRoles = permissions?.includes('roles.manage') ?? false;
const canBackup = permissions?.includes('backup.download') ?? false;
const canViewAudit = permissions?.includes('audit.view') ?? false;
---

<Layout>
  <nav class="bg-gray-800 text-white p-4 flex gap-4 flex-wrap">
    <a href="/admin/dashboard" class="hover:underline">Dashboard</a>
    <a href="/admin/reports/profit" class="hover:underline">Profit Report</a>
    <a href="/admin/reports/sales" class="hover:underline">Sales History</a>
    <a href="/admin/products" class="hover:underline">Products</a>
    <a href="/admin/transactions" class="hover:underline">Transactions</a>
    <a href="/admin/categories" class="hover:underline">Categories</a>
    <a href="/admin/suppliers" class="hover:underline">Suppliers</a>
    <a href="/admin/sales/new" class="hover:underline">New Sale</a>
    <a href="/admin/settings" class="hover:underline">Settings</a>
    {canManageUsers && <a href="/admin/users" class="hover:underline">Users</a>}
    {canManageRoles && <a href="/admin/roles" class="hover:underline">Roles</a>}
    {canViewAudit && <a href="/admin/audit" class="hover:underline">Audit Logs</a>}
    {canBackup && <a href="/admin/backup" class="hover:underline">Backup</a>}
    <form method="post" action="/api/logout" class="ml-auto">
      <button type="submit" class="hover:underline">Logout</button>
    </form>
  </nav>
  <main class="p-4">
    <slot />
  </main>
</Layout>