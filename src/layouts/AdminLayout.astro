---
import Layout from './Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import TopBar from '../components/TopBar.astro';

const { user, t } = Astro.locals;
if (!user) return Astro.redirect('/admin/login');
// Determine the page title from the request URL (simple mapping)
let pageTitle = 'Dashboard';
const path = Astro.url.pathname;
if (path.includes('/products')) pageTitle = t('products');
else if (path.includes('/transactions')) pageTitle = t('transactions');
else if (path.includes('/categories')) pageTitle = t('categories');
else if (path.includes('/suppliers')) pageTitle = t('suppliers');
else if (path.includes('/sales/new')) pageTitle = t('new_sale');
else if (path.includes('/settings')) pageTitle = t('settings');
else if (path.includes('/users')) pageTitle = t('users');
else if (path.includes('/roles')) pageTitle = t('roles');
else if (path.includes('/audit')) pageTitle = t('audit_logs');
else if (path.includes('/backup')) pageTitle = t('backup');
else if (path.includes('/reports/profit')) pageTitle = t('profit_report');
else if (path.includes('/reports/sales')) pageTitle = t('sales_history');
---

<Layout>
  <div class="flex min-h-screen bg-ash-50 dark:bg-ash-900">
    <Sidebar />
    <div class="flex-1 md:ml-64">
      <TopBar title={pageTitle} />
      <main class="p-4 md:p-6">
        <slot />
      </main>
    </div>
  </div>
</Layout>