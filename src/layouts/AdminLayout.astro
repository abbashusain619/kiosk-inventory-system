---
import Layout from './Layout.astro';
const { userId } = Astro.locals;
if (!userId) {
  return Astro.redirect('/admin/login');
}
---

<Layout>
  <nav class="bg-gray-800 text-white p-4 flex gap-4 flex-wrap">
    <a href="/admin/dashboard" class="hover:underline">Dashboard</a>
    <a href="/admin/products" class="hover:underline">Products</a>
    <a href="/admin/transactions" class="hover:underline">Transactions</a>
    <a href="/admin/categories" class="hover:underline">Categories</a>
    <a href="/admin/suppliers" class="hover:underline">Suppliers</a>
    <a href="/admin/sales/new" class="hover:underline">New Sale</a>
    <a href="/admin/settings" class="hover:underline">Settings</a>
    <form method="post" action="/api/logout" class="ml-auto">
      <button type="submit" class="hover:underline">Logout</button>
    </form>
  </nav>
  <main class="p-4">
    <slot />
  </main>
</Layout>